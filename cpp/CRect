//클래스의 활용법, 사각형 넓이 구하기
#include<iostream>
using namespace std;

class CRect{
private:
    int wid, hig;

public:
    CRect(){ wid=4; hig=3;}
    int Area(){
        return wid * hig;
    }
};

int main(){
    CRect r;
    cout << r.Area();
}


/* 
main으로부터 값을 받아 private 안의 변수를 다룰 수 있다.
-> private안의 값은 원래 다루지 못하지만 public 안의 "CRect(int a, int b) {wid =a; hig=b;}"를 통해 값을 부여할 수 있음 
    -> 이것으로 private안의 변수에 들어갈 값을 제한할 수 있음 
#include<iostream>
using namespace std;

class CRect{
private:
    int wid, hig;

public:
    CRect(){ wid=4; hig=3;}
    CRect(int a, int b) {wid =a; hig=b;}
    int Area(){
        return wid * hig;
    }
};

int main(){
    CRect me;
    CRect r(2,3);
    cout << r.Area();
}

CRect(){ wid=4; hig=3;} - CRect me; //연결
=> class에서 CRect를 생성해 값을 넣었기 때문에 main에서 함수를 호출해야 사용 가능 

CRect(int a, int b) {wid =a; hig=b;} - CRect r(2,3); //연결 
=> class에서 CRect(int a, int b)로 값을 지정하고, wid, hig를 변수에 연결해 들어갈 값을 지정해줬음으로 main에서 함수를 호출하고 a,b의 방식을 통해 값을 넣을 수 있음 


