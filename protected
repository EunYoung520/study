#include<iostream>
using namespace std;

class CPoly {
protected: //protected 뒤에는 콜론(:)을 사용한
	int wid, hig;
};

class r: public CPoly { //class 내부의 private를 사용하지 않은 캐 CPoly에 있는 protected에서 상속받아 사용한다. 
public: 다. 
	r() {wid = 2; hig = 3;}
	int Tarea() {return wid * hig;}
};

class t : public CPoly {
public:
	t() {wid = 2; hig = 3;}
	int Rarea() {return (wid * hig) / 2;}
};

int main() {
	r re;
	t tr;
	cout << re.Tarea() << '\n';
	cout << tr.Rarea();
}

